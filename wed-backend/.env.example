# Database
MONGO_URI=mongodb://127.0.0.1:27017/usforever

# AWS
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
S3_BUCKET=
S3_PREFIX=
S3_DELIMITER=/

# MSG91
MSG91_AUTH_KEY=

# JWT — JWT_SECRET is required (>= 32 chars). Server refuses to start without it
# or with the placeholder. Generate one with: `openssl rand -hex 32`.
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Photographer
PHOTOGRAPHER_JWT_SECRET=
PHOTOGRAPHER_JWT_EXPIRES_IN=12h
PHOTOGRAPHER_WEB_APP=http://localhost:5173

# App
APP_SCHEME=usforever
EXPO_GO_BASE=
PUBLIC_APP_BASE_URL=

# TV
TV_PAIR_TTL_MINUTES=5
TV_TOKEN_TTL=12h

# Server
PORT=1337
HOST=0.0.0.0
